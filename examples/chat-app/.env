# --- Vite dev-proxy targets (read server-side by vite.config.ts) ---
# Browser talks to /ov and /llm; Vite forwards to these to dodge CORS.
OPENVIKING_URL=http://127.0.0.1:1933
OPENAI_BASE_URL=https://omniroute.hency.in/v1
PORT=8788

# --- Browser config (VITE_ prefix = exposed to client; example only, no secrets) ---
VITE_OPENAI_API_KEY=sk-e353cd6594f915d4-333b07-359d91c5
VITE_OPENVIKING_API_KEY=openviking-dev-key
VITE_OPENVIKING_ACCOUNT=ov_example
VITE_OPENVIKING_USER_ID=ov_demo

# Optional: restrict/order the model dropdown (first = default). Empty = all from /models.
# Only list models your gateway has credentials for — others 422/404.
VITE_OPENAI_MODELS=cx/gpt-5.5,cx/gpt-5.4-mini,cx/gpt-5.2,cx/gpt-5.3-codex
