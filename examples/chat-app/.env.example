# --- Vite dev-proxy targets (read server-side by vite.config.ts) ---
# The agent loop runs in the browser and talks to /ov and /llm; Vite forwards
# these to dodge CORS. No app code runs server-side.
OPENVIKING_URL=http://127.0.0.1:1933
OPENAI_BASE_URL=https://api.openai.com/v1
PORT=8788

# --- Browser config (VITE_ prefix = exposed to client; example only) ---
VITE_OPENAI_API_KEY=sk-your-key
VITE_OPENVIKING_API_KEY=openviking-dev-key

# Global-per-diner memory model: constant account, userId = the diner id
VITE_OPENVIKING_ACCOUNT=grubgenie
VITE_OPENVIKING_USER_ID=diner-demo

# Optional: restrict/order the model dropdown (first = default). Empty = all from /models.
# Only list models your gateway has credentials for — others 422/404.
VITE_OPENAI_MODELS=
